# Legend Intelligence — environment configuration
# Copy to .env and fill in your values. The .env file is gitignored (never committed).

# LLM Provider selection:
#   anthropic-cli  = Claude Pro/Max subscription via `claude` CLI (default, no key needed)
#   anthropic-api  = Anthropic REST API (requires ANTHROPIC_API_KEY below)
#   gemini         = Google Gemini API (requires GEMINI_API_KEY below)
LLM_PROVIDER=anthropic-cli

# Anthropic REST API key (only needed for LLM_PROVIDER=anthropic-api)
# ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key (only needed for LLM_PROVIDER=gemini)
# GEMINI_API_KEY=...

# Optional: override the server port (default: 8080)
# PORT=8080
